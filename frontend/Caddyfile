# Serves the built site and proxies /api to the backend.
# The site address is a free sslip.io hostname that resolves to the server IP,
# so Caddy automatically gets a free Let's Encrypt certificate (HTTPS on 443).
healthpa.3-230-42-191.sslip.io {
	encode gzip

	# API traffic goes to the FastAPI container (same origin, no CORS headaches).
	handle /api/* {
		reverse_proxy api:8000
	}

	# Everything else is the single-page app.
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
