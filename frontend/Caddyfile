# Serves the built site and proxies /api to the backend. Plain HTTP on :80.
# For a real domain with automatic HTTPS, change :80 to your domain name.
:80 {
	encode gzip

	# API traffic goes to the FastAPI container (same origin, no CORS headaches).
	handle /api/* {
		reverse_proxy api:8000
	}

	# Everything else is the single-page app.
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
