# ============================================================
# HealthPA — Environment Variables Reference
# Copy to .env and fill in real values before running locally.
# NEVER commit .env to version control.
# ============================================================

# ── Project ──────────────────────────────────────────────────
PROJECT_NAME=HealthPA
VERSION=0.1.0
DEBUG=True

# ── Security ─────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/healthpa
# Leave empty to reuse DATABASE_URL (schema-isolated) for tests
TEST_DATABASE_URL=
TEST_DATABASE_SCHEMA=healthpa_test

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── File Storage ─────────────────────────────────────────────
OCR_UPLOAD_DIR=data/ocr_uploads
MAX_UPLOAD_SIZE=10485760

# ── AI / Groq ────────────────────────────────────────────────
GROQ_API_KEY=

# ── AI Layer (LangGraph / RAG / HITL) ────────────────────────
# Master switch. False -> skip grounded layer, use rule/LLM fallback only.
AI_ENABLED=True

# Chat model. Default drives a local LM Studio server (OpenAI-compatible).
#   CHAT_LLM_PROVIDER: openai | lmstudio | groq | anthropic
CHAT_LLM_PROVIDER=openai
CHAT_LLM_MODEL=google/gemma-4-12b-qat
LLM_BASE_URL=http://localhost:1234/v1
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
CHAT_LLM_TEMPERATURE=0.0
CHAT_MAX_TOKENS=1024
CHAT_LLM_TIMEOUT=60

# Embeddings. Default = nomic via LM Studio (768-dim). Use "local" for offline.
#   EMBEDDING_PROVIDER: openai | lmstudio | local
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5
EMBEDDING_BASE_URL=
EMBEDDING_DIM=768

# Vector store: pinecone (prod) | memory (tests/offline)
RAG_VECTOR_BACKEND=pinecone
PINECONE_API_KEY=
PINECONE_INDEX=healthpa-ai
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# Retrieval tuning
RAG_FETCH_K=12
RAG_TOP_K=4
RAG_RERANK=True
RAG_RERANK_LLM=False
CHAT_MAX_REWRITES=1

# Per-coder/hospital long-term memory
LONG_TERM_MEMORY=True

# HITL checkpointer: postgres (durable) | memory
HITL_CHECKPOINTER=postgres

# Policy-QA web search (non-authoritative; excluded from code grounding)
ENABLE_WEB_SEARCH=True
TAVILY_API_KEY=

# Observability (optional; auto-off in tests)
LANGSMITH_TRACING=False
LANGSMITH_PROJECT=HealthPA-AI
# LANGSMITH_ENDPOINT and LANGSMITH_API_KEY are read directly by the langsmith SDK
LANGSMITH_ENDPOINT=
LANGSMITH_API_KEY=

# ── Webhooks ─────────────────────────────────────────────────
# Comma-separated list of webhook URLs to notify on PA status changes
WEBHOOK_URLS=

# ── AWS SES — Email ──────────────────────────────────────────
# IAM user must have ses:SendEmail permission on the verified sender domain.
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_SES_REGION=us-east-1
# Must be a verified SES identity (email address or domain)
SES_SENDER_EMAIL=noreply@yourdomain.com

# ── Admin & Security Alerts ───────────────────────────────────
# Receives fraud / account-lockout notifications
ADMIN_EMAIL=admin@yourdomain.com
# Number of consecutive failed logins before account is locked (default 5)
FAILED_LOGIN_MAX_ATTEMPTS=5

# ── Frontend ─────────────────────────────────────────────────
# Used to build verification and password-reset links in emails
FRONTEND_URL=http://localhost:3000
